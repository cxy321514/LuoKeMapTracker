<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1e"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 头部 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗺️ 洛克王国世界"
            android:textSize="26sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="手机地图实时追踪器"
            android:textSize="14sp"
            android:textColor="#666688"
            android:layout_marginBottom="20dp" />

        <!-- 状态卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔴 未启动"
                android:textSize="20sp"
                android:textColor="#ff6b6b"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_coords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待定位..."
                android:textSize="14sp"
                android:textColor="#aaaacc"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_region"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#8899bb"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_map_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ 未选择大地图"
                android:textSize="13sp"
                android:textColor="#888899" />
        </LinearLayout>

        <!-- 游戏检测状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_game_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏸ 游戏未运行"
                android:textSize="14sp"
                android:textColor="#888899" />

            <Switch
                android:id="@+id/switch_auto_detect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动检测 "
                android:textColor="#888899"
                android:textSize="12sp"
                android:checked="true" />
        </LinearLayout>

        <!-- 地图来源 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗺️ 地图来源"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_select_map"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📁 从本地选择大地图"
            android:textSize="14sp"
            android:backgroundTint="#2196F3"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_download_map"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🌐 从网络下载地图"
            android:textSize="14sp"
            android:backgroundTint="#00BCD4"
            android:textColor="#ffffff"
            android:layout_marginBottom="16dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a40"
            android:layout_marginBottom="16dp" />

        <!-- 控制按钮 -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀 开始追踪"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#ffffff"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⏹ 停止追踪"
            android:textSize="14sp"
            android:backgroundTint="#f44336"
            android:textColor="#ffffff"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a40"
            android:layout_marginBottom="16dp" />

        <!-- 资源点设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 资源点标注"
                android:textSize="14sp"
                android:textColor="#ffffff"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switch_show_resources"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_resource_filters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:layout_marginBottom="16dp" />
        <!-- 动态添加 CheckBox -->

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a40"
            android:layout_marginBottom="16dp" />

        <!-- 校准区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📐 小地图区域校准"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_calibration_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="区域: (0, 0) 300x300"
            android:textSize="12sp"
            android:textColor="#666688"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="X 偏移"
            android:textSize="12sp"
            android:textColor="#888899" />
        <SeekBar
            android:id="@+id/sb_minimap_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="0"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Y 偏移"
            android:textSize="12sp"
            android:textColor="#888899" />
        <SeekBar
            android:id="@+id/sb_minimap_y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="2000"
            android:progress="0"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="宽度"
            android:textSize="12sp"
            android:textColor="#888899" />
        <SeekBar
            android:id="@+id/sb_minimap_w"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="800"
            android:progress="300"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高度"
            android:textSize="12sp"
            android:textColor="#888899" />
        <SeekBar
            android:id="@+id/sb_minimap_h"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="800"
            android:progress="300"
            android:layout_marginBottom="16dp" />

        <!-- 使用说明 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2a2a40"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 使用方法"
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. 导入大地图（本地选择或网络下载）\n2. 开启「自动检测」→ 打开游戏自动追踪\n3. 进入游戏后用校准条框出小地图位置\n4. 点击「开始追踪」授予权限\n5. 悬浮窗显示实时位置 + 资源点\n6. 双击悬浮窗可展开/收起\n7. 点击 📍 图标开关资源点显示\n\n🟢 绿色 = 高置信度 | 🟡 黄色 = 中等 | 🔴 红色 = 低"
            android:textSize="12sp"
            android:textColor="#555577"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>
</ScrollView>
